### -------------------------------------------------------
### Webhook Event – POST /api/webhook
### Visual Studio / VS Code REST Client (.http)
###
### Prerequisites
###   1. Replace {{baseUrl}} with your running host, e.g. https://localhost:7001
###   2. Replace {{endpointToken}} with the EndPointToken stored in WebhookEndpoints
###   3. Set {{timestamp}} to the current Unix epoch (seconds):
###        PowerShell: [DateTimeOffset]::UtcNow.ToUnixTimeSeconds()
###   4. Compute {{signature}} with PowerShell (see bottom of file)
### -------------------------------------------------------

@baseUrl       = http://localhost:5062
@endpointToken = U3xhcGkubXZwYWNjZXNzLm9ubGluZQowYjA2NmM3MjllNWY0YTA2YjU3MWRlNzUwNWEyMDViZi05NGNmNWE2NWQzYTk0ODcwYmU3N2QxNjM0NDRlN2VkZgphcGktY2lkLThhYTJkZjNiCkBwVnpuaWNSOHRUT3BoMG0lOFI2byRhTDFmcUc3VmJYCmFwaS1tdnAtaW50ZWdyYXRpb24temFwaWVyCjUwMDg0Mg
@timestamp     = 1781740800
@signature     = f5da49a6849db8916db21427dc78894e4684b2a07d04c897c35f3e5ac08c27ba

### --- event.create (Access / Door event) ---
POST {{baseUrl}}/api/webhook
Content-Type: application/json
X-Endpoint-Token: {{endpointToken}}
X-Timestamp: {{timestamp}}
X-Signature: {{signature}}

{
  "eventType": "event.create",
  "provider": "MVP",
  "payload": {
    "priority": 1,
    "category": 2,
    "panelId": 101,
    "eventDate": "2026-06-17T08:30:00Z",
    "deviceId": 205,
    "status": 1,
    "facilityNo": 1,
    "badge": 123456,
    "class": "Access",
    "description": "Door opened",
    "name": "Main Entrance",
    "hasPhoto": false,
    "hasVideo": false,
    "responseRequired": false,
    "sequenceNoFromLock": 0,
    "recordCount": 1
  }
}

###

