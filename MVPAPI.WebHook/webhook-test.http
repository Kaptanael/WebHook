### --- event.operatorresponse (Relay event) ---
POST {{baseUrl}}/api/webhook
Content-Type: application/json
X-Endpoint-Token: {{endpointToken}}
X-Timestamp: {{timestamp}}
X-Signature: {{signature}}

{
  "eventType": "event.operatorresponse",
  "provider": "MVP",
  "payload": {
    "priority": 1,
    "category": 1,
    "panelId": 101,
    "eventDate": "2026-06-17T08:32:00Z",
    "deviceId": 402,
    "status": 1,
    "description": "Relay activated by operator",
    "name": "Gate Relay",
    "hasPhoto": false,
    "sequenceNoFromLock": 2,
    "recordCount": 1
  }
}

###

### --- No token (signature-only auth) ---
### Signature required; endpoint still needs X-Endpoint-Token to resolve –
### this will return a validation error unless token-less routing is supported.
POST {{baseUrl}}/api/webhook
Content-Type: application/json
X-Timestamp: {{timestamp}}
X-Signature: {{signature}}

{
  "eventType": "event.create",
  "provider": "ThirdParty",
  "payload": {
    "description": "External system event",
    "sequenceNoFromLock": 0,
    "recordCount": 1
  }
}

###
### -------------------------------------------------------
### Compute X-Signature in PowerShell
### -------------------------------------------------------
###
###   $secret    = "YOUR_ENDPOINT_TOKEN_HERE"
###   $timestamp = [DateTimeOffset]::UtcNow.ToUnixTimeSeconds()
###   $body      = Get-Content .\payload.json -Raw   # or paste JSON inline
###   $message   = "$timestamp.$body"
###
###   $key  = [Text.Encoding]::UTF8.GetBytes($secret)
###   $data = [Text.Encoding]::UTF8.GetBytes($message)
###   $hmac = [System.Security.Cryptography.HMACSHA256]::new($key)
###   [BitConverter]::ToString($hmac.ComputeHash($data)).Replace("-","").ToLower()
###
### -------------------------------------------------------
### Header summary
### -------------------------------------------------------
###   X-Endpoint-Token  optional  identifies + authenticates the endpoint
###   X-Timestamp       required  Unix seconds, rejected if >5 min old
###   X-Signature       required when X-Endpoint-Token is absent;
###                     optional (but validated) when token is present
### -------------------------------------------------------
